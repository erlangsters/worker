root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.erl]
indent_style = space
indent_size = 4

[*.hrl]
indent_style = space
indent_size = 4

[rebar.config]
indent_style = space
indent_size = 2

[src/*.app.src]
indent_style = space
indent_size = 2
